# Environment Configuration

# Database
DATABASE_URL=postgresql+psycopg://avm_app:change-me@127.0.0.1:5432/real_estate_avm
POSTGRES_DB=real_estate_avm
POSTGRES_USER=avm_app
POSTGRES_PASSWORD=replace-with-strong-postgres-password

# API
API_HOST=localhost
API_PORT=8000
API_RELOAD=true

# JWT Authentication (required)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-a-random-64-char-secret
JWT_EXPIRE_MINUTES=120
JWT_REFRESH_DAYS=14
# Local admin backdoor (X-AVM-Admin-Session): 0 = OFF (secure default). 1 = enable for local demo only.
ALLOW_LOCAL_ADMIN_SESSION=0

# Google OAuth 2.0 (optional third-party login)
# Store real values only in local .env / Docker secrets / GitHub Secrets.
# If a client secret has ever been pasted in chat or committed, rotate it before use.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback
GOOGLE_OAUTH_FRONTEND_REDIRECT=http://127.0.0.1:5173/
GOOGLE_OAUTH_ALLOWED_REDIRECT_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Research Lab (required)
RESEARCH_LAB_ACCESS_CODE=avm-research-2026

# CORS for local frontend/backend
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

# Nova AI Assistant
# Use a legitimate local key/token. Do not put real secrets in the submitted zip.
ANTHROPIC_API_KEY=
# Optional Claude-compatible local token. RUN_BACKEND.ps1 also reads it from
# %USERPROFILE%\.claude\settings.json at runtime without writing it to source.
# ANTHROPIC_AUTH_TOKEN=
# If .claude/settings.json contains ANTHROPIC_DEFAULT_OPUS_MODEL, RUN_BACKEND.ps1
# prefers that model automatically. You can override it with NOVA_MODEL below.
# Default official endpoint. If RUN_BACKEND.ps1 loads ANTHROPIC_AUTH_TOKEN from
# %USERPROFILE%\.claude\settings.json, it also uses that file's ANTHROPIC_BASE_URL.
ANTHROPIC_BASE_URL=https://api.anthropic.com
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_MODEL=gpt-4o-mini
# Stable demo model. Opus may be slower or temporarily unavailable on some proxy providers.
NOVA_MODEL=claude-sonnet-4-6
NOVA_VISION_MODEL=claude-opus-4-8
NOVA_TIMEOUT_SECONDS=12
# Optional limit for the Claude CLI bridge when HTTP provider is unstable.
# NOVA_CLAUDE_CLI_MAX_BUDGET_USD=0.05
# Keep CLI bridge off by default because a stuck CLI call can freeze chat.
NOVA_ENABLE_CLAUDE_CLI_BRIDGE=0
# Turn on image payloads so Nova can answer screenshot/photo prompts directly.
NOVA_ENABLE_IMAGE_INPUT=1

# Impact tab: 1 = fast comparable/rule analysis, 0 = load full ML/SHAP engine.
IMPACT_FAST_MODE=1

# Model serving is pinned by models/ACTIVE_MODEL.json; no "latest file" fallback.
